#!/usr/bin/env python3
"""Collect Unisphere PowerMax data deterministically and fail closed."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sys
import tempfile
import time
from pathlib import Path
from typing import Any, Callable
from urllib.parse import quote

import requests

MAX_RESPONSE_BYTES = 20 * 1024 * 1024
MAX_CACHE_BYTES = 50 * 1024 * 1024


class UnisphereError(RuntimeError):
    """Raised when a selected data source cannot be collected safely."""


def camel_to_snake(name: str) -> str:
    name = re.sub(r"(.)([A-Z][a-z]+)", r"\1_\2", name)
    return re.sub(r"([a-z0-9])([A-Z])", r"\1_\2", name).lower()


def clean_item(value: Any) -> str:
    text = str(value).replace("|", "/").replace("\r", " ").replace("\n", " ")
    return text[:1024]


def json_object(value: Any, label: str) -> dict[str, Any]:
    if not isinstance(value, dict):
        raise UnisphereError(f"{label} must be a JSON object")
    return value


def json_list(value: Any, label: str) -> list[Any]:
    if not isinstance(value, list):
        raise UnisphereError(f"{label} must be a JSON list")
    return value


class PmaxConnector:
    def __init__(
        self,
        username: str,
        password: str,
        host: str,
        *,
        ssl_verify: bool,
        api_version: int,
        timeout: float = 90.0,
    ):
        self.api_version = api_version
        self.base_url = f"https://{host}/univmax/restapi"
        self.host = host
        self.timeout = timeout
        self.ssl_verify = ssl_verify
        self.request_count = 0
        self.symmetrix_info: dict[str, dict[str, Any]] = {}
        self.session = requests.Session()
        self.session.trust_env = False
        self.session.auth = requests.auth.HTTPBasicAuth(username, password)
        self.session.headers.update(
            {"Accept": "application/json", "Content-Type": "application/json"}
        )

    def request_json(
        self,
        method: str,
        endpoint: str,
        *,
        payload: dict[str, Any] | None = None,
    ) -> dict[str, Any]:
        self.request_count += 1
        try:
            response = self.session.request(
                method,
                self.base_url + endpoint,
                json=payload,
                verify=self.ssl_verify,
                timeout=self.timeout,
                allow_redirects=False,
                stream=True,
            )
        except requests.RequestException as exc:
            raise UnisphereError(f"request failed for {endpoint}: {exc}") from exc
        if response.is_redirect:
            raise UnisphereError(f"unexpected redirect for {endpoint}")
        body = bytearray()
        for chunk in response.iter_content(chunk_size=65536):
            body.extend(chunk)
            if len(body) > MAX_RESPONSE_BYTES:
                raise UnisphereError(f"response too large for {endpoint}")
        if not 200 <= response.status_code < 300:
            raise UnisphereError(
                f"HTTP {response.status_code} returned for {endpoint}"
            )
        try:
            data = json.loads(body)
        except (UnicodeDecodeError, json.JSONDecodeError) as exc:
            raise UnisphereError(f"invalid JSON returned for {endpoint}") from exc
        return json_object(data, endpoint)

    def get(self, endpoint: str) -> dict[str, Any]:
        return self.request_json("GET", endpoint)

    def post(self, endpoint: str, payload: dict[str, Any]) -> dict[str, Any]:
        return self.request_json("POST", endpoint, payload=payload)

    def get_symmetrix(self) -> list[str]:
        data = self.get(f"/{self.api_version}/sloprovisioning/symmetrix")
        return [clean_item(item) for item in json_list(data.get("symmetrixId"), "symmetrixId")]

    def ensure_symmetrix_info(self) -> None:
        if self.symmetrix_info:
            return
        for symm_id in self.get_symmetrix():
            endpoint = (
                f"/{self.api_version}/sloprovisioning/symmetrix/"
                f"{quote(symm_id, safe='')}"
            )
            self.symmetrix_info[symm_id] = self.get(endpoint)

    def get_symmetrix_name(self, symmetrix_id: str) -> str:
        self.ensure_symmetrix_info()
        return clean_item(
            self.symmetrix_info.get(symmetrix_id, {}).get(
                "display_name", symmetrix_id
            )
        )

    def is_symmetrix_local(self, symmetrix_id: str) -> bool:
        self.ensure_symmetrix_info()
        return self.symmetrix_info.get(symmetrix_id, {}).get("local") is True


def selected_symmetrix(connector: PmaxConnector, include_remote: bool) -> list[str]:
    result: list[str] = []
    for symm_id in connector.get_symmetrix():
        if include_remote or connector.is_symmetrix_local(symm_id):
            result.append(symm_id)
    return result


def section(name: str, lines: list[str]) -> list[str]:
    return [f"<<<{name}:sep(124)>>>", *lines]


def collect_srp(connector: PmaxConnector, args: argparse.Namespace) -> list[str]:
    lines: list[str] = []
    for symm_id in selected_symmetrix(connector, args.enable_remote_sym_checks):
        base = (
            f"/{connector.api_version}/sloprovisioning/symmetrix/"
            f"{quote(symm_id, safe='')}/srp"
        )
        for srp_id in json_list(connector.get(base).get("srpId", []), "srpId"):
            srp = clean_item(srp_id)
            detail = connector.get(f"{base}/{quote(srp, safe='')}")
            name = connector.get_symmetrix_name(symm_id)
            lines.append(
                f"SYMMETRIX_{name}_{srp}|{json.dumps(detail, separators=(',', ':'))}"
            )
    return section("unisphere_powermax_srp", lines)


def collect_directors(connector: PmaxConnector, args: argparse.Namespace) -> list[str]:
    lines: list[str] = []
    for symm_id in selected_symmetrix(connector, args.enable_remote_sym_checks):
        base = f"/{connector.api_version}/system/symmetrix/{quote(symm_id, safe='')}/director"
        for director_id in json_list(
            connector.get(base).get("directorId", []), "directorId"
        ):
            director = clean_item(director_id)
            detail = connector.get(f"{base}/{quote(director, safe='')}")
            name = connector.get_symmetrix_name(symm_id)
            lines.append(
                f"SYMMETRIX_{name}_{director}|{json.dumps(detail, separators=(',', ':'))}"
            )
    return section("unisphere_powermax_director", lines)


def collect_health_score(connector: PmaxConnector, args: argparse.Namespace) -> list[str]:
    lines: list[str] = []
    for symm_id in selected_symmetrix(connector, args.enable_remote_sym_checks):
        endpoint = f"/{connector.api_version}/system/symmetrix/{quote(symm_id, safe='')}/health"
        metrics = json_list(
            connector.get(endpoint).get("health_score_metric", []),
            "health_score_metric",
        )
        for metric in metrics:
            item = json_object(metric, "health score metric")
            if item.get("metric") is None:
                continue
            name = connector.get_symmetrix_name(symm_id)
            metric_name = clean_item(item["metric"])
            lines.append(
                f"SYMMETRIX_{name}_{metric_name}|{json.dumps(item, separators=(',', ':'))}"
            )
    return section("unisphere_powermax_health_score", lines)


def collect_health_checks(connector: PmaxConnector, args: argparse.Namespace) -> list[str]:
    lines: list[str] = []
    for symm_id in selected_symmetrix(connector, args.enable_remote_sym_checks):
        base = (
            f"/{connector.api_version}/system/symmetrix/"
            f"{quote(symm_id, safe='')}/health/health_check"
        )
        identifiers = json_list(
            connector.get(base).get("health_check_id", []), "health_check_id"
        )
        for identifier in identifiers:
            detail = connector.get(f"{base}/{quote(clean_item(identifier), safe='')}")
            date = detail.get("date", 0)
            for raw_result in json_list(detail.get("testResult", []), "testResult"):
                result = json_object(raw_result, "health check result").copy()
                if result.get("item_name") is None:
                    continue
                result["date"] = date
                item_name = clean_item(result["item_name"]).replace(" ", "_")
                name = connector.get_symmetrix_name(symm_id)
                lines.append(
                    f"SYMMETRIX_{name}_{item_name}|"
                    f"{json.dumps(result, separators=(',', ':'))}"
                )
    return section("unisphere_powermax_health_check", lines)


def collect_array_performance(connector: PmaxConnector, args: argparse.Namespace) -> list[str]:
    now = int(time.time() * 1000)
    keys = json_list(
        connector.get("/performance/Array/keys").get("arrayInfo"), "arrayInfo"
    )
    lines: list[str] = []
    metrics = [
        "BEIOs", "BEReadReqs", "BEWriteReqs", "DeviceWPEvents",
        "FEReadReqs", "FEWriteReqs", "HostMBs", "FEHitReqs", "HostIOs",
        "FEReadHitReqs", "FEReadMissReqs", "FEReqs", "ReadResponseTime",
        "WriteResponseTime", "SystemWPEvents", "BEReqs", "PercentCacheWP",
        "WPCount", "SystemMaxWPLimit", "FEWriteHitReqs", "FEWriteMissReqs",
    ]
    for raw in keys:
        key = json_object(raw, "arrayInfo item")
        symm_id = clean_item(key.get("symmetrixId"))
        if not symm_id:
            raise UnisphereError("arrayInfo item has no symmetrixId")
        if not args.enable_remote_sym_checks and not connector.is_symmetrix_local(symm_id):
            continue
        performance: dict[str, Any] = {}
        for data_format in ("Maximum", "Average"):
            payload = {
                "startDate": now - 5 * 60 * 1000,
                "endDate": now,
                "symmetrixId": symm_id,
                "dataFormat": data_format,
                "metrics": metrics,
            }
            result_list = json_object(
                connector.post("/performance/Array/metrics", payload).get("resultList"),
                "resultList",
            )
            results = json_list(result_list.get("result"), "performance result")
            if not results:
                raise UnisphereError(f"no {data_format} performance result for {symm_id}")
            performance[data_format] = results[-1]
        name = connector.get_symmetrix_name(symm_id)
        lines.append(
            f"SYMMETRIX_{name}|{json.dumps(performance, separators=(',', ':'))}"
        )
    return section("unisphere_powermax_array_performance", lines)


def collect_port_groups(connector: PmaxConnector, args: argparse.Namespace) -> list[str]:
    lines: list[str] = []
    for symm_id in selected_symmetrix(connector, args.enable_remote_sym_checks):
        base = (
            f"/{connector.api_version}/sloprovisioning/symmetrix/"
            f"{quote(symm_id, safe='')}/portgroup"
        )
        groups = json_list(connector.get(base).get("portGroupId", []), "portGroupId")
        for raw_group in groups:
            group = clean_item(raw_group)
            detail = connector.get(f"{base}/{quote(group, safe='')}")
            ports = json_list(detail.get("symmetrixPortKey", []), "symmetrixPortKey")
            port_info: list[dict[str, Any]] = []
            for raw_port in ports:
                port = json_object(raw_port, "symmetrixPortKey item")
                director = quote(clean_item(port.get("directorId")), safe="")
                port_id = quote(clean_item(port.get("portId")), safe="")
                endpoint = (
                    f"/{connector.api_version}/system/symmetrix/"
                    f"{quote(symm_id, safe='')}/director/{director}/port/{port_id}"
                )
                port_info.append(connector.get(endpoint))
            name = connector.get_symmetrix_name(symm_id)
            lines.append(
                f"SYMMETRIX_{name}_{group}|"
                f"{json.dumps(port_info, separators=(',', ':'))}"
            )
    return section("unisphere_powermax_port_group", lines)


def collect_alerts(connector: PmaxConnector, args: argparse.Namespace) -> list[str]:
    data = connector.get(f"/{connector.api_version}/system/alert_summary")
    lines: list[str] = []
    if data.get("serverAlertSummary") is not None:
        lines.append(
            "Server Alert Summary|"
            + json.dumps(data["serverAlertSummary"], separators=(",", ":"))
        )
    for raw_summary in json_list(data.get("symmAlertSummary", []), "symmAlertSummary"):
        summary = json_object(raw_summary, "symm alert summary")
        symm_id = clean_item(summary.get("symmId"))
        if not symm_id:
            continue
        if not args.enable_remote_sym_checks and not connector.is_symmetrix_local(symm_id):
            continue
        name = connector.get_symmetrix_name(symm_id)
        for key, value in summary.items():
            if "summary" in key.lower():
                lines.append(
                    f"SYMMETRIX_{name}_{camel_to_snake(key)}|"
                    f"{json.dumps(value, separators=(',', ':'))}"
                )
    return section("unisphere_powermax_alerts", lines)


def cache_path(connector: PmaxConnector) -> Path:
    root = Path(os.environ["OMD_ROOT"]) / "tmp"
    digest = hashlib.sha256(connector.host.encode()).hexdigest()[:16]
    return root / f"agent_unisphere_powermax_masking_{digest}.json"


def read_cache(path: Path, max_age_minutes: int) -> dict[str, list[str]] | None:
    try:
        metadata = path.lstat()
    except FileNotFoundError:
        return None
    if path.is_symlink() or not path.is_file() or metadata.st_size > MAX_CACHE_BYTES:
        raise UnisphereError("masking-view cache is not a valid regular file")
    if time.time() - metadata.st_mtime >= max_age_minutes * 60:
        return None
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, UnicodeError, json.JSONDecodeError) as exc:
        raise UnisphereError("masking-view cache is invalid") from exc
    payload = json_object(data, "masking-view cache")
    volumes = json_list(payload.get("volumes"), "cached volumes")
    ports = json_list(payload.get("ports"), "cached ports")
    if not all(isinstance(item, str) for item in [*volumes, *ports]):
        raise UnisphereError("masking-view cache contains non-string lines")
    return {"volumes": volumes, "ports": ports}


def atomic_write_cache(path: Path, data: dict[str, list[str]]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    descriptor, temporary_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    temporary = Path(temporary_name)
    try:
        os.fchmod(descriptor, 0o600)
        with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
            json.dump(data, handle, separators=(",", ":"))
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temporary, path)
    except BaseException:
        try:
            temporary.unlink()
        except FileNotFoundError:
            pass
        raise


def collect_masking_views(connector: PmaxConnector, args: argparse.Namespace) -> list[str]:
    path = cache_path(connector)
    cached = read_cache(path, args.cache)
    if cached is not None:
        return section("unisphere_powermax_volume", cached["volumes"]) + section(
            "unisphere_powermax_port", cached["ports"]
        )

    volumes_seen: set[tuple[str, str]] = set()
    ports_seen: set[tuple[str, str]] = set()
    volume_lines: list[str] = []
    port_lines: list[str] = []
    for symm_id in selected_symmetrix(connector, args.enable_remote_sym_checks):
        name = connector.get_symmetrix_name(symm_id)
        base = (
            f"/{connector.api_version}/sloprovisioning/symmetrix/"
            f"{quote(symm_id, safe='')}/maskingview"
        )
        views = json_list(connector.get(base).get("maskingViewId", []), "maskingViewId")
        for raw_view in views:
            view = clean_item(raw_view)
            connections = json_list(
                connector.get(f"{base}/{quote(view, safe='')}/connections").get(
                    "maskingViewConnection", []
                ),
                "maskingViewConnection",
            )
            for raw_connection in connections:
                connection = json_object(raw_connection, "masking view connection")
                volume = clean_item(connection.get("volumeId"))
                if volume and (symm_id, volume) not in volumes_seen:
                    volumes_seen.add((symm_id, volume))
                    detail = connector.get(
                        f"/{connector.api_version}/sloprovisioning/symmetrix/"
                        f"{quote(symm_id, safe='')}/volume/{quote(volume, safe='')}"
                    ).copy()
                    if detail.get("allocated_percent") is not None:
                        detail["maskingView"] = view
                        volume_lines.append(
                            f"SYMMETRIX_{name}_{volume}|"
                            f"{json.dumps(detail, separators=(',', ':'))}"
                        )
                dir_port = clean_item(connection.get("dir_port"))
                if dir_port and (symm_id, dir_port) not in ports_seen:
                    parts = dir_port.split(":", 1)
                    if len(parts) != 2:
                        raise UnisphereError(f"invalid dir_port {dir_port!r}")
                    ports_seen.add((symm_id, dir_port))
                    detail = connector.get(
                        f"/{connector.api_version}/system/symmetrix/"
                        f"{quote(symm_id, safe='')}/director/"
                        f"{quote(parts[0], safe='')}/port/{quote(parts[1], safe='')}"
                    )
                    port = json_object(detail.get("symmetrixPort"), "symmetrixPort")
                    port_lines.append(
                        f"SYMMETRIX_{name}_{clean_item(dir_port)}|"
                        f"{json.dumps(port, separators=(',', ':'))}"
                    )
    atomic_write_cache(path, {"volumes": volume_lines, "ports": port_lines})
    return section("unisphere_powermax_volume", volume_lines) + section(
        "unisphere_powermax_port", port_lines
    )


DATA_SOURCES: tuple[tuple[str, Callable[[PmaxConnector, argparse.Namespace], list[str]]], ...] = (
    ("get_srp_info", collect_srp),
    ("get_director_info", collect_directors),
    ("get_health_score_info", collect_health_score),
    ("get_health_check_info", collect_health_checks),
    ("get_array_performance_info", collect_array_performance),
    ("get_port_group_info", collect_port_groups),
    ("get_alert_info", collect_alerts),
    ("get_masking_view_info", collect_masking_views),
)


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--user", required=True)
    parser.add_argument("--password", required=True)
    parser.add_argument("--port", default=8443, type=int)
    parser.add_argument("--cache_time", default=30, type=int, dest="cache")
    parser.add_argument("--hostname", required=True)
    parser.add_argument("--api_version", default=100, type=int, dest="api_version")
    parser.add_argument("--enable_remote_sym_checks", action="store_true")
    parser.add_argument("--no_cert_check", action="store_true")
    for legacy_name, _ in DATA_SOURCES:
        parser.add_argument(f"--disable_{legacy_name}", action="store_true")
    args = parser.parse_args(argv)
    if not 1 <= args.port <= 65535:
        parser.error("--port must be between 1 and 65535")
    if not 1 <= args.api_version <= 999:
        parser.error("--api_version must be between 1 and 999")
    if not 1 <= args.cache <= 1440:
        parser.error("--cache_time must be between 1 and 1440 minutes")
    return args


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv)
    connector = PmaxConnector(
        args.user,
        args.password,
        f"{args.hostname}:{args.port}",
        ssl_verify=not args.no_cert_check,
        api_version=args.api_version,
    )
    try:
        version = connector.get("/version").get("version")
        if not isinstance(version, str) or not version:
            raise UnisphereError("version endpoint returned no version")
        connector.ensure_symmetrix_info()
        output = ["<<<check_mk>>>", "Version: agent_unisphere_powermax-3.1"]
        for legacy_name, collector in DATA_SOURCES:
            if getattr(args, f"disable_{legacy_name}"):
                continue
            output.extend(collector(connector, args))
    except (UnisphereError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1
    sys.stdout.write("\n".join(output) + "\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
