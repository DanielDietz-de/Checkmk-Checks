#!/usr/bin/env python3
"""Create Ivanti/Cherwell incidents from Checkmk notifications."""

from __future__ import annotations

import ast
import json
import re
import sys
from pathlib import Path
from typing import Any
from urllib.parse import quote, urlsplit, urlunsplit

import requests
from cmk.notification_plugins import utils

SITE_RE = re.compile(r"^[A-Za-z0-9_-]+$")
MAX_FIELDS = 100
MAX_FIELD_VALUE_LENGTH = 16384


class CherwellError(RuntimeError):
    """Raised when the notification cannot be completed safely."""


def validate_https_url(value: str, label: str) -> str:
    parsed = urlsplit(value.strip())
    if parsed.scheme != "https" or not parsed.hostname:
        raise CherwellError(f"{label} must be an absolute HTTPS URL")
    if parsed.username or parsed.password:
        raise CherwellError(f"{label} must not contain embedded credentials")
    if parsed.query or parsed.fragment:
        raise CherwellError(f"{label} must not contain a query or fragment")
    return urlunsplit((parsed.scheme, parsed.netloc, parsed.path.rstrip("/"), "", ""))


def validate_ca_bundle(value: str | None, label: str) -> bool | str:
    if not value:
        return True
    path = Path(value)
    if not path.is_absolute() or not path.is_file() or path.is_symlink():
        raise CherwellError(f"{label} must be an absolute regular CA bundle file")
    return str(path)


def parse_field_mappings(raw: Any, label: str) -> list[dict[str, Any]]:
    if raw in (None, "", []):
        return []
    value = raw
    if isinstance(raw, str):
        try:
            value = json.loads(raw)
        except json.JSONDecodeError:
            try:
                value = ast.literal_eval(raw)
            except (SyntaxError, ValueError, TypeError) as exc:
                raise CherwellError(f"{label} is not valid JSON or a literal list") from exc
    if not isinstance(value, list):
        raise CherwellError(f"{label} must be a list")
    if len(value) > MAX_FIELDS:
        raise CherwellError(f"{label} exceeds the {MAX_FIELDS}-field limit")

    fields: list[dict[str, Any]] = []
    for index, item in enumerate(value):
        if not isinstance(item, dict):
            raise CherwellError(f"{label}[{index}] must be an object")
        field_id = item.get("fieldId", item.get("field_id"))
        field_value = item.get("value")
        if not isinstance(field_id, str) or not field_id.strip():
            raise CherwellError(f"{label}[{index}] has no fieldId")
        if not isinstance(field_value, (str, int, float, bool)) and field_value is not None:
            raise CherwellError(f"{label}[{index}] has an unsupported value")
        normalized_value = "" if field_value is None else str(field_value)
        if len(normalized_value) > MAX_FIELD_VALUE_LENGTH:
            raise CherwellError(f"{label}[{index}] value is too long")
        fields.append(
            {
                "dirty": bool(item.get("dirty", True)),
                "fieldId": field_id.strip(),
                "value": normalized_value,
            }
        )
    return fields


class NotifyCherwell:
    def __init__(self, context: dict[str, str] | None = None):
        self.context = utils.collect_context() if context is None else context
        context_data = self.context
        self.api_url = validate_https_url(context_data["PARAMETER_API_URL"], "API URL")
        self.token_url = validate_https_url(
            context_data["PARAMETER_TOKEN_URL"], "token URL"
        )
        self.client_id = context_data["PARAMETER_CLIENT_ID"]
        self.username = context_data["PARAMETER_USERNAME"]
        self.password = utils.get_password_from_env_or_context(
            key="PARAMETER_PASSWORD", context=context_data
        )
        self.automation_secret = utils.get_password_from_env_or_context(
            key="PARAMETER_AUTOMATION_SECRET", context=context_data
        )
        self.business_object_id = context_data["PARAMETER_BUSINESS_OBJECT_ID"].strip()
        self.description_field_id = context_data[
            "PARAMETER_DESCRIPTION_FIELD_ID"
        ].strip()
        if not self.business_object_id or not self.description_field_id:
            raise CherwellError("business object and description field IDs are required")

        self.cache_scope = context_data.get("PARAMETER_CACHE_SCOPE", "Tenant").strip()
        if not self.cache_scope:
            raise CherwellError("cache scope must not be empty")
        self.insert_fields = parse_field_mappings(
            context_data.get("PARAMETER_INSERT_FIELDS_JSON", "[]"),
            "insert_fields_json",
        )
        self.update_fields = parse_field_mappings(
            context_data.get("PARAMETER_UPDATE_FIELDS_JSON", "[]"),
            "update_fields_json",
        )
        self.recovery_mode = context_data.get(
            "PARAMETER_RECOVERY_MODE", "ignore"
        ).lower()
        if self.recovery_mode not in {"ignore", "create"}:
            raise CherwellError("recovery mode must be ignore or create")

        try:
            self.timeout = float(context_data.get("PARAMETER_TIMEOUT", "10"))
        except ValueError as exc:
            raise CherwellError("timeout must be numeric") from exc
        if not 0.5 <= self.timeout <= 120:
            raise CherwellError("timeout must be between 0.5 and 120 seconds")

        self.verify_cherwell = validate_ca_bundle(
            context_data.get("PARAMETER_CA_BUNDLE"), "Cherwell CA bundle"
        )
        self.verify_checkmk = validate_ca_bundle(
            context_data.get("PARAMETER_CMK_CA_BUNDLE"), "Checkmk CA bundle"
        )
        self.cmk_base_url = self._build_checkmk_base_url(
            context_data["PARAMETER_CMK_SERVER"],
            context_data["PARAMETER_CMK_SITE"],
        )
        self.cmk_site = context_data["PARAMETER_CMK_SITE"]
        self.event_id = context_data.get("EC_ID") or None

        self.cherwell = requests.Session()
        self.cherwell.trust_env = False
        self.checkmk = requests.Session()
        self.checkmk.trust_env = False

    @staticmethod
    def _build_checkmk_base_url(server: str, site: str) -> str:
        if not SITE_RE.fullmatch(site):
            raise CherwellError("Checkmk site name contains invalid characters")
        parsed = urlsplit(f"https://{server.strip()}")
        if not parsed.hostname or parsed.username or parsed.password:
            raise CherwellError("Checkmk server must be a hostname with optional port")
        if parsed.path not in {"", "/"} or parsed.query or parsed.fragment:
            raise CherwellError("Checkmk server must not contain a path, query, or fragment")
        return urlunsplit(
            (
                "https",
                parsed.netloc,
                f"/{site}/check_mk/api/1.0",
                "",
                "",
            )
        )

    def _request_json(
        self,
        session: requests.Session,
        method: str,
        url: str,
        *,
        verify: bool | str,
        expected_empty: bool = False,
        **kwargs: Any,
    ) -> dict[str, Any]:
        try:
            response = session.request(
                method,
                url,
                timeout=self.timeout,
                verify=verify,
                allow_redirects=False,
                **kwargs,
            )
        except requests.RequestException as exc:
            raise CherwellError(f"request to {urlsplit(url).hostname} failed: {exc}") from exc
        if response.is_redirect:
            raise CherwellError(f"unexpected redirect from {urlsplit(url).hostname}")
        if not 200 <= response.status_code < 300:
            detail = response.text.strip()
            if len(detail) > 500:
                detail = detail[:500] + "..."
            raise CherwellError(
                f"HTTP {response.status_code} from {urlsplit(url).hostname}: "
                f"{detail or 'no response body'}"
            )
        if expected_empty or not response.content:
            return {}
        try:
            data = response.json()
        except ValueError as exc:
            raise CherwellError(
                f"invalid JSON from {urlsplit(url).hostname}"
            ) from exc
        if not isinstance(data, dict):
            raise CherwellError(f"non-object JSON from {urlsplit(url).hostname}")
        return data

    def get_login_token(self) -> str:
        data = self._request_json(
            self.cherwell,
            "POST",
            self.token_url,
            verify=self.verify_cherwell,
            data={
                "grant_type": "password",
                "client_id": self.client_id,
                "username": self.username,
                "password": self.password,
            },
        )
        token = data.get("access_token")
        if not isinstance(token, str) or not token:
            raise CherwellError("token response has no access_token")
        return token

    def acknowledge_event(self, ticket_number: str) -> None:
        if self.event_id is None:
            return
        event_id = quote(str(self.event_id), safe="")
        url = (
            f"{self.cmk_base_url}/objects/event_console/{event_id}"
            "/actions/update_and_acknowledge/invoke"
        )
        self._request_json(
            self.checkmk,
            "POST",
            url,
            verify=self.verify_checkmk,
            expected_empty=True,
            headers={
                "Authorization": f"Bearer automation {self.automation_secret}",
                "Accept": "application/json",
                "Content-Type": "application/json",
            },
            json={
                "phase": "ack",
                "site_id": self.cmk_site,
                "change_comment": ticket_number,
            },
        )

    def _description(self) -> str:
        context = self.context
        what = context.get("WHAT", "")
        host = context.get("HOSTNAME", "Undefined")
        is_host = what == "HOST"
        service = "HOST" if is_host else context.get("SERVICEDESC", "Undefined")
        state = (
            context.get("HOSTSTATE", "Undefined")
            if is_host
            else context.get("SERVICESTATE", "Undefined")
        )
        output = (
            context.get("HOSTOUTPUT", "")
            if is_host
            else context.get("SERVICEOUTPUT", "")
        )
        notification_type = context.get("NOTIFICATIONTYPE", "UNKNOWN")
        contacts = context.get("CONTACTS", "")
        event_time = context.get("SHORTDATETIME", context.get("LONGDATETIME", ""))
        host_link = (
            f"{self.cmk_base_url.removesuffix('/check_mk/api/1.0')}"
            f"/check_mk/view.py?host={quote(host, safe='')}&view_name=host"
        )
        lines = [
            f"Checkmk notification: {notification_type}",
            f"Host: {host}",
            f"Application: {service}",
            f"Time: {event_time}",
            f"State: {state}",
            f"Output: {output}",
            f"Contacts: {contacts}",
            f"Host link: {host_link}",
        ]
        if self.event_id is not None:
            event_link = (
                f"{self.cmk_base_url.removesuffix('/check_mk/api/1.0')}"
                f"/check_mk/view.py?site={quote(self.cmk_site, safe='')}"
                f"&event_id={quote(str(self.event_id), safe='')}&view_name=ec_event"
            )
            lines.extend((f"Event ID: {self.event_id}", f"Event link: {event_link}"))
        return "\n".join(lines)

    def build_insert_payload(self) -> dict[str, Any]:
        fields = [
            {
                "dirty": True,
                "fieldId": self.description_field_id,
                "value": self._description(),
            },
            *self.insert_fields,
        ]
        return {
            "busObId": self.business_object_id,
            "cacheScope": self.cache_scope,
            "fields": fields,
            "persist": True,
        }

    def build_update_payload(self, ticket_number: str) -> dict[str, Any]:
        return {
            "busObPublicId": ticket_number,
            "busObId": self.business_object_id,
            "cacheScope": self.cache_scope,
            "fields": self.update_fields,
            "persist": True,
        }

    def notify(self) -> int:
        notification_type = self.context.get("NOTIFICATIONTYPE")
        if notification_type not in {"PROBLEM", "RECOVERY"}:
            print(f"Ignoring unsupported notification type {notification_type!r}")
            return 0
        if notification_type == "RECOVERY" and self.recovery_mode == "ignore":
            print("Recovery notification ignored by configured recovery mode.")
            return 0

        token = self.get_login_token()
        headers = {
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
            "Accept": "application/json",
        }
        created = self._request_json(
            self.cherwell,
            "POST",
            self.api_url,
            verify=self.verify_cherwell,
            headers=headers,
            json=self.build_insert_payload(),
        )
        ticket_id = created.get("busObPublicId")
        if not isinstance(ticket_id, str) or not ticket_id or len(ticket_id) > 256:
            raise CherwellError("incident response has no valid busObPublicId")

        if self.update_fields:
            self._request_json(
                self.cherwell,
                "POST",
                self.api_url,
                verify=self.verify_cherwell,
                headers=headers,
                json=self.build_update_payload(ticket_id),
            )

        if notification_type == "PROBLEM" and self.event_id is not None:
            self.acknowledge_event(ticket_id)

        print(f"Cherwell incident: {ticket_id}")
        return 0


def main() -> int:
    return NotifyCherwell().notify()


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except (CherwellError, KeyError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        raise SystemExit(1) from exc
