#!/usr/bin/env python3
"""Remove superseded notification pairs from the Checkmk notification spool."""

from __future__ import annotations

import ast
from os import environ, listdir, stat, unlink
from os.path import isfile
from pathlib import Path
from typing import Any

MAX_SPOOL_FILE_SIZE = 1024 * 1024


class SpoolFormatError(ValueError):
    """Raised when a spool file is not a supported literal notification record."""


def load_context(spool_file: Path) -> dict[str, Any]:
    try:
        size = spool_file.stat().st_size
    except OSError as exc:
        raise SpoolFormatError(f"cannot stat file: {exc}") from exc
    if size > MAX_SPOOL_FILE_SIZE:
        raise SpoolFormatError(
            f"file exceeds the {MAX_SPOOL_FILE_SIZE}-byte parser limit"
        )

    try:
        raw = spool_file.read_text(encoding="utf-8")
    except (OSError, UnicodeError) as exc:
        raise SpoolFormatError(f"cannot read file: {exc}") from exc

    try:
        record = ast.literal_eval(raw)
    except (SyntaxError, ValueError, TypeError, MemoryError, RecursionError) as exc:
        raise SpoolFormatError("file is not a valid Python literal") from exc

    if not isinstance(record, dict):
        raise SpoolFormatError("top-level value must be a dictionary")
    context = record.get("context")
    if not isinstance(context, dict):
        raise SpoolFormatError("record has no dictionary context")

    required = ("WHAT", "NOTIFICATIONTYPE", "HOSTNAME")
    missing = [key for key in required if not isinstance(context.get(key), str)]
    if missing:
        raise SpoolFormatError(
            "context is missing string field(s): " + ", ".join(missing)
        )
    if context["WHAT"] == "SERVICE" and not isinstance(
        context.get("SERVICEDESC"), str
    ):
        raise SpoolFormatError("service context is missing SERVICEDESC")
    return context


def main() -> int:
    path = Path(environ["OMD_ROOT"]) / "var/check_mk/notify/spool"
    files_unsorted = listdir(path)
    files = list(map(lambda f: (stat(path / f)[9], f), files_unsorted))
    files.sort(key=lambda tup: tup[0])

    entries = {
        "Hosts": {"Downtime": {}, "State": {}},
        "Services": {"Downtime": {}, "State": {}},
    }
    stats = {
        "Hosts": {"Downtime": 0, "State": 0},
        "Services": {"Downtime": 0, "State": 0},
    }

    count_skip = 0
    total_count = 0
    for file in files:
        total_count += 1
        spool_file = path / file[1]
        try:
            info = load_context(spool_file)
        except SpoolFormatError as exc:
            count_skip += 1
            print(f"Skipped {count_skip}: {spool_file}: {exc}")
            continue

        if info.get("WHAT") == "HOST":
            if info["NOTIFICATIONTYPE"] == "DOWNTIMESTART":
                entries["Hosts"]["Downtime"][info["HOSTNAME"]] = file[1]

            elif info["NOTIFICATIONTYPE"] == "DOWNTIMEEND":
                if info["HOSTNAME"] in entries["Hosts"]["Downtime"].keys():
                    if isfile(path / entries["Hosts"]["Downtime"][info["HOSTNAME"]]):
                        unlink(path / entries["Hosts"]["Downtime"][info["HOSTNAME"]])

                    if isfile(spool_file):
                        unlink(spool_file)

                    del entries["Hosts"]["Downtime"][info["HOSTNAME"]]
                    stats["Hosts"]["Downtime"] += 1

            elif info["NOTIFICATIONTYPE"] == "PROBLEM":
                entries["Hosts"]["State"][info["HOSTNAME"]] = file[1]

            elif info["NOTIFICATIONTYPE"] == "RECOVERY":
                if info["HOSTNAME"] in entries["Hosts"]["State"].keys():
                    if isfile(path / entries["Hosts"]["State"][info["HOSTNAME"]]):
                        unlink(path / entries["Hosts"]["State"][info["HOSTNAME"]])

                    if isfile(spool_file):
                        unlink(spool_file)

                    del entries["Hosts"]["State"][info["HOSTNAME"]]
                    stats["Hosts"]["State"] += 1

        elif info.get("WHAT") == "SERVICE":
            name = f"{info['HOSTNAME']}###{info['SERVICEDESC']}"

            if info["NOTIFICATIONTYPE"] == "DOWNTIMESTART":
                entries["Services"]["Downtime"][name] = file[1]

            elif info["NOTIFICATIONTYPE"] == "DOWNTIMEEND":
                if name in entries["Services"]["Downtime"].keys():
                    if isfile(path / entries["Services"]["Downtime"][name]):
                        unlink(path / entries["Services"]["Downtime"][name])

                    if isfile(spool_file):
                        unlink(spool_file)

                    del entries["Hosts"]["Services"][name]
                    stats["Services"]["Downtime"] += 1

            elif info["NOTIFICATIONTYPE"] == "PROBLEM":
                entries["Services"]["State"][name] = file[1]

            elif info["NOTIFICATIONTYPE"] == "RECOVERY":
                if name in entries["Services"]["State"].keys():
                    if isfile(path / entries["Services"]["State"][name]):
                        unlink(path / entries["Services"]["State"][name])

                    if isfile(spool_file):
                        unlink(spool_file)

                    del entries["Services"]["State"][name]
                    stats["Services"]["State"] += 1
        else:
            print(f"Invalid File {spool_file}")

    print("#" * 80)
    print(f"# {'Hosts':35}#    # {'Services':35}#")
    print(
        f"# Deleted downtimes: {stats['Hosts']['Downtime']:15} #    # "
        f"Deleted downtimes: {stats['Services']['Downtime']:15} #"
    )
    print(
        f"#    Deleted states: {stats['Hosts']['State']:15} #    # "
        f"   Deleted states: {stats['Services']['State']:15} #"
    )
    print(f"# Total Files: {total_count}\t\t\t\t\t\t\t #")
    print("#" * 80)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
