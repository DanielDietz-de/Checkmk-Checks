#!/usr/bin/env python3
"""Create and close ServiceNow incidents from Checkmk notifications."""

from __future__ import annotations

import json
import re
import sys
from pathlib import Path
from typing import Any
from urllib.parse import urljoin, urlsplit, urlunsplit

import requests
from requests.auth import HTTPBasicAuth

from cmk.notification_plugins.utils import (
    collect_context,
    get_password_from_env_or_context,
)

MAX_RESPONSE_BYTES = 1024 * 1024
MAX_TEXT_LENGTH = 16384
SNOW_GROUP_RE = re.compile(r"^SNOW_(\d+)(?:_|$)")
CONTROL_RE = re.compile(r"[\x00-\x1f\x7f]")


class ServiceNowError(RuntimeError):
    """Raised when a ServiceNow notification cannot be delivered safely."""


def safe_text(value: Any, *, limit: int = MAX_TEXT_LENGTH) -> str:
    text = CONTROL_RE.sub(" ", str(value))
    text = " ".join(text.split())
    return text[:limit]


def validate_base_url(value: str) -> str:
    parsed = urlsplit(value.strip())
    if parsed.scheme != "https" or not parsed.hostname:
        raise ServiceNowError("API URL must be an absolute HTTPS URL")
    if parsed.username or parsed.password:
        raise ServiceNowError("API URL must not contain embedded credentials")
    if parsed.query or parsed.fragment:
        raise ServiceNowError("API URL must not contain a query or fragment")
    path = parsed.path.rstrip("/") + "/"
    return urlunsplit(("https", parsed.netloc, path, "", ""))


def validate_proxy(value: str | None) -> dict[str, str]:
    if not value:
        return {}
    parsed = urlsplit(value.strip())
    if parsed.scheme != "https" or not parsed.hostname:
        raise ServiceNowError("proxy must be an absolute HTTPS URL")
    if parsed.username or parsed.password or parsed.query or parsed.fragment:
        raise ServiceNowError(
            "proxy must not contain credentials, a query, or a fragment"
        )
    proxy = urlunsplit(("https", parsed.netloc, parsed.path.rstrip("/"), "", ""))
    return {"https": proxy}


def validate_ca_bundle(value: str | None) -> bool | str:
    if not value:
        return True
    path = Path(value)
    if not path.is_absolute() or not path.is_file() or path.is_symlink():
        raise ServiceNowError("CA bundle must be an absolute regular file")
    return str(path)


def choose_assignment_group(group_names: str | None) -> str:
    selected = "SNOW_000_OS"
    selected_number = 0
    if not group_names:
        return selected
    for raw_group in group_names.split(","):
        group = raw_group.strip()
        match = SNOW_GROUP_RE.match(group)
        if match is None:
            continue
        number = int(match.group(1))
        if number > selected_number:
            selected = group
            selected_number = number
    return safe_text(selected, limit=256)


def service_assignment_override(context: dict[str, str]) -> str | None:
    # Correct key first; retain the historical duplicated SVC key for migration.
    value = context.get("SERVICE_SNOW_RESP_GRP_2") or context.get(
        "SERVICE_SVC_SNOW_RESP_GRP_2"
    )
    if not value:
        return None
    return safe_text(value, limit=256)


def on_call_service_level(context: dict[str, str], service_level: str) -> str:
    try:
        state_id = int(context.get("SERVICESTATEID", "-1"))
    except ValueError:
        state_id = -1
    all_off = (
        context.get("SERVICELABEL_SNOW_onCALLDUTY_ALL", "") == "OFF"
        and state_id in {1, 2}
    )
    crit_off = (
        context.get("SERVICELABEL_SNOW_onCALLDUTY_CRIT", "") == "OFF"
        and state_id == 2
    )
    warn_off = (
        context.get("SERVICELABEL_SNOW_onCALLDUTY_WARN", "") == "OFF"
        and state_id == 1
    )
    return "0" if all_off or crit_off or warn_off else service_level


def source_id(context: dict[str, str]) -> str:
    site = context.get("OMD_SITE", "unknown-site")
    host = context.get("HOSTNAME", "unknown-host")
    if context.get("WHAT") == "SERVICE":
        return f"{site}|{host}|{context.get('SERVICEDESC', 'unknown-service')}"
    return f"{site}|{host}"


def build_problem_payload(context: dict[str, str]) -> dict[str, Any]:
    host = context.get("HOSTNAME", "unknown-host")
    site = context.get("OMD_SITE", "unknown-site")
    contacts = context.get("CONTACTS", "")
    what = context.get("WHAT", "HOST")
    assignment_override = context.get("HOST_SNOW_RESP_GRP")

    if what == "HOST":
        management_pack = {"hostname": host, "contacts": contacts}
        severity = context.get("HOSTSTATE", "UNKNOWN")
        plugin_output = context.get("HOSTOUTPUT", "")
        service_level = context.get("HOST_SL", "")
        contact_groups = context.get("HOSTCONTACTGROUPNAMES", "")
    elif what == "SERVICE":
        service = context.get("SERVICEDESC", "unknown-service")
        management_pack = {
            "hostname": host,
            "servicename": service,
            "contacts": contacts,
        }
        severity = context.get("SERVICESTATE", "UNKNOWN")
        plugin_output = context.get("SERVICEOUTPUT", "")
        service_level = context.get("SVC_SL", "") or context.get("HOST_SL", "")
        contact_groups = context.get("SERVICECONTACTGROUPNAMES", "") or context.get(
            "HOSTCONTACTGROUPNAMES", ""
        )
        assignment_override = service_assignment_override(context) or assignment_override
        service_level = on_call_service_level(context, service_level)
    else:
        raise ServiceNowError(f"unsupported notification object {what!r}")

    disposition = {
        "0": "Keine_Bereitschaft",
        "10": "Bereitschaft",
    }.get(service_level, "N/A")
    payload: dict[str, Any] = {
        "QUELLE": "Checkmk",
        "QUELLEID": source_id(context),
        "ZIEL": "ServiceNow",
        "FUNKTION": "create",
        "FQDN": safe_text(host, limit=512),
        "MP": {
            key: safe_text(value, limit=2048)
            for key, value in management_pack.items()
        },
        "SERVERITY": safe_text(severity, limit=64),
        "DIENSTKONTO": safe_text(site, limit=256),
        "EVENTZEITPUNKT": safe_text(
            context.get("MICROTIME", context.get("LONGDATETIME", "")),
            limit=128,
        ),
        "KURZBESCHREIBUNG": safe_text(plugin_output),
        "LANGBESCHREIBUNG": "",
        "ASSIGNMENT": choose_assignment_group(contact_groups),
        "DISPOSITION": disposition,
    }
    if assignment_override:
        payload["ASSIGNMENT_GROUP"] = safe_text(assignment_override, limit=256)
    return payload


def build_recovery_payload(context: dict[str, str]) -> dict[str, str]:
    return {
        "QUELLEID": source_id(context),
        "ZIEL": "ServiceNow",
        "ZIELID": "TBD",
        "FUNKTION": "close",
    }


def read_response(response: requests.Response) -> dict[str, Any]:
    declared = response.headers.get("Content-Length")
    if declared:
        try:
            if int(declared) > MAX_RESPONSE_BYTES:
                raise ServiceNowError("response exceeds the size limit")
        except ValueError:
            pass
    body = bytearray()
    for chunk in response.iter_content(chunk_size=65536):
        body.extend(chunk)
        if len(body) > MAX_RESPONSE_BYTES:
            raise ServiceNowError("response exceeds the size limit")
    if not 200 <= response.status_code < 300:
        raise ServiceNowError(
            f"ServiceNow gateway returned HTTP {response.status_code}"
        )
    if not body:
        return {}
    try:
        data = json.loads(body)
    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise ServiceNowError("ServiceNow gateway returned invalid JSON") from exc
    if not isinstance(data, dict):
        raise ServiceNowError("ServiceNow gateway returned non-object JSON")
    return data


def deliver(
    *,
    base_url: str,
    endpoint: str,
    payload: dict[str, Any],
    user: str,
    password: str,
    timeout: float,
    verify: bool | str,
    proxies: dict[str, str],
    session: requests.Session | None = None,
) -> int:
    client = requests.Session() if session is None else session
    client.trust_env = False
    url = urljoin(base_url, endpoint)
    try:
        response = client.post(
            url,
            json=payload,
            auth=HTTPBasicAuth(user, password),
            timeout=timeout,
            verify=verify,
            proxies=proxies,
            allow_redirects=False,
            stream=True,
        )
    except requests.RequestException as exc:
        # Incident create/close operations are not retried after ambiguous
        # transport errors because the gateway may already have applied them.
        raise ServiceNowError(f"request failed: {exc}") from exc
    if response.is_redirect:
        raise ServiceNowError("ServiceNow gateway returned an unexpected redirect")
    read_response(response)
    print(f"ServiceNow {payload['FUNKTION']} request accepted.")
    return 0


def main() -> int:
    context = collect_context()
    notification_type = context.get("NOTIFICATIONTYPE")
    if notification_type == "PROBLEM":
        endpoint = "checkmk/incident/create"
        payload = build_problem_payload(context)
    elif notification_type == "RECOVERY":
        endpoint = "checkmk/incident/close"
        payload = build_recovery_payload(context)
    else:
        print(f"Ignoring notification type {notification_type!r}.")
        return 0

    try:
        timeout = float(context.get("PARAMETER_TIMEOUT", "15"))
    except ValueError as exc:
        raise ServiceNowError("timeout must be numeric") from exc
    if not 0.5 <= timeout <= 120:
        raise ServiceNowError("timeout must be between 0.5 and 120 seconds")

    return deliver(
        base_url=validate_base_url(context["PARAMETER_API_URL"]),
        endpoint=endpoint,
        payload=payload,
        user=context["PARAMETER_API_USER"],
        password=get_password_from_env_or_context(
            key="PARAMETER_API_PASSWORD", context=context
        ),
        timeout=timeout,
        verify=validate_ca_bundle(context.get("PARAMETER_CA_BUNDLE")),
        proxies=validate_proxy(context.get("PARAMETER_PROXY")),
    )


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except (ServiceNowError, KeyError, OSError) as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        raise SystemExit(2) from exc
