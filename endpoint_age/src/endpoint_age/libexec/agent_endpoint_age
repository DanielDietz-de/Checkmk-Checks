#!/usr/bin/env python3
"""Probe public HTTPS endpoints for freshness without delegated SSRF."""

from __future__ import annotations

import argparse
import ipaddress
import json
import re
import socket
import sys
from datetime import datetime, timezone
from email.utils import parsedate_to_datetime
from typing import Any
from urllib.parse import urlsplit

import requests

MAX_RESPONSE_BYTES = 1024 * 1024
MAX_ENDPOINTS = 100
MAX_JSON_PATH_LENGTH = 512
MAX_NAME_LENGTH = 256


class EndpointError(RuntimeError):
    """Raised when an endpoint is unsafe or cannot be probed reliably."""


def validate_public_https_url(value: str) -> str:
    parsed = urlsplit(value.strip())
    if parsed.scheme != "https" or not parsed.hostname:
        raise EndpointError("URL must be an absolute HTTPS URL")
    if parsed.username or parsed.password or parsed.fragment:
        raise EndpointError("URL must not contain credentials or a fragment")
    try:
        addresses = {
            result[4][0]
            for result in socket.getaddrinfo(
                parsed.hostname,
                parsed.port or 443,
                type=socket.SOCK_STREAM,
            )
        }
    except socket.gaierror as exc:
        raise EndpointError(f"DNS resolution failed: {exc}") from exc
    if not addresses:
        raise EndpointError("DNS resolution returned no addresses")
    unsafe = [address for address in addresses if not ipaddress.ip_address(address).is_global]
    if unsafe:
        raise EndpointError("URL resolves to a non-public address")
    return value.strip()


def parse_date(value: Any) -> datetime | None:
    if value is None:
        return None
    text = str(value).strip()
    if not text or len(text) > 256:
        return None
    try:
        parsed = parsedate_to_datetime(text)
    except (TypeError, ValueError):
        parsed = None
    if parsed is None:
        try:
            parsed = datetime.fromisoformat(text.replace("Z", "+00:00"))
        except ValueError:
            return None
    return parsed.replace(tzinfo=timezone.utc) if parsed.tzinfo is None else parsed


def lookup_json_path(data: Any, path: str) -> Any:
    if not path or len(path) > MAX_JSON_PATH_LENGTH:
        return None
    current = data
    for raw_segment in path.split("."):
        match = re.fullmatch(r"([^\[\]]+)(?:\[(\d+)\])?", raw_segment)
        if match is None or not isinstance(current, dict):
            return None
        current = current.get(match.group(1))
        if match.group(2) is not None:
            if not isinstance(current, list):
                return None
            index = int(match.group(2))
            if index >= len(current):
                return None
            current = current[index]
    return current


def compute_age(source: str, headers: requests.structures.CaseInsensitiveDict, body: bytes):
    now = datetime.now(timezone.utc)
    if source == "age_header":
        raw = headers.get("Age")
        try:
            age = int(float(raw))
        except (TypeError, ValueError):
            return None, None, "response has no numeric Age header"
        return max(0, age), f"Age: {raw}", None

    if source.startswith("date_header"):
        header = source.partition(":")[2].strip() or "Last-Modified"
        if not re.fullmatch(r"[A-Za-z0-9-]{1,128}", header):
            return None, None, "invalid response header name"
        raw = headers.get(header)
        parsed = parse_date(raw)
        if parsed is None:
            return None, None, f"cannot parse {header} response header"
        return max(0, int((now - parsed).total_seconds())), f"{header}: {raw}", None

    if source.startswith("json_path:"):
        path = source.partition(":")[2].strip()
        try:
            decoded = json.loads(body)
        except (UnicodeDecodeError, json.JSONDecodeError):
            return None, None, "response is not valid UTF-8 JSON"
        if not isinstance(decoded, (dict, list)):
            return None, None, "JSON root must be an object or list"
        value = lookup_json_path(decoded, path)
        if value is None:
            return None, None, "configured JSON path was not found"
        if isinstance(value, (int, float)) and not isinstance(value, bool):
            return max(0, int(value)), f"{path} = {value}", None
        parsed = parse_date(value)
        if parsed is None:
            return None, None, "JSON path value is not a supported date"
        return max(0, int((now - parsed).total_seconds())), f"{path} = {value}", None

    return None, None, "unsupported freshness source"


def read_bounded(response: requests.Response) -> bytes:
    body = bytearray()
    for chunk in response.iter_content(chunk_size=65536):
        body.extend(chunk)
        if len(body) > MAX_RESPONSE_BYTES:
            raise EndpointError("response exceeds the 1 MiB limit")
    return bytes(body)


def probe_endpoint(spec: dict[str, Any], session: requests.Session) -> dict[str, Any]:
    name = str(spec.get("name") or "endpoint")[:MAX_NAME_LENGTH]
    result = {
        "name": name,
        "url": str(spec.get("url") or "")[:2048],
        "source": str(spec.get("source") or "age_header")[:1024],
        "ok": False,
        "error": None,
        "http_status": None,
        "age_seconds": None,
        "detail": None,
    }
    try:
        url = validate_public_https_url(result["url"])
        timeout = float(spec.get("timeout", 15.0))
        if not 0.5 <= timeout <= 60:
            raise EndpointError("timeout must be between 0.5 and 60 seconds")
        response = session.get(
            url,
            headers={"User-Agent": "checkmk-endpoint-age/2.0"},
            timeout=timeout,
            verify=True,
            allow_redirects=False,
            stream=True,
        )
        result["http_status"] = response.status_code
        if response.is_redirect:
            raise EndpointError("endpoint returned an unexpected redirect")
        if not 200 <= response.status_code < 300:
            raise EndpointError(f"endpoint returned HTTP {response.status_code}")
        body = read_bounded(response)
        age, detail, error = compute_age(result["source"], response.headers, body)
        if error:
            raise EndpointError(error)
        result.update(ok=True, age_seconds=age, detail=str(detail)[:1024])
    except (EndpointError, requests.RequestException, ValueError) as exc:
        result["error"] = str(exc)[:1024]
    return result


def parse_arguments(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--endpoint", action="append", default=[])
    args = parser.parse_args(argv)
    if not args.endpoint:
        parser.error("At least one --endpoint is required")
    if len(args.endpoint) > MAX_ENDPOINTS:
        parser.error(f"At most {MAX_ENDPOINTS} endpoints are supported")
    return args


def main(argv: list[str] | None = None) -> int:
    args = parse_arguments(argv)
    session = requests.Session()
    session.trust_env = False
    print("<<<endpoint_age:sep(0)>>>")
    for raw in args.endpoint:
        try:
            spec = json.loads(raw)
            if not isinstance(spec, dict):
                raise ValueError("endpoint spec must be a JSON object")
            result = probe_endpoint(spec, session)
        except (json.JSONDecodeError, ValueError) as exc:
            result = {"name": "invalid endpoint", "ok": False, "error": str(exc)[:1024]}
        print(json.dumps(result, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
