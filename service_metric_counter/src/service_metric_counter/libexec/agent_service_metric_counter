#!/usr/bin/env python3
"""Aggregate Checkmk metrics using only the local site's automation secret."""

from __future__ import annotations

import ipaddress
import json
import sys
from os import environ
from pathlib import Path
from urllib.parse import urlsplit, urlunsplit

import requests


class UnsafeSiteUrl(ValueError):
    """Raised when a local automation secret would leave the local site."""


def _is_loopback_host(hostname: str | None) -> bool:
    if hostname is None:
        return False
    if hostname.lower() == "localhost":
        return True
    try:
        return ipaddress.ip_address(hostname).is_loopback
    except ValueError:
        return False


def local_site_base_url(raw_url: str) -> str:
    site = environ.get("OMD_SITE")
    if not site:
        raise UnsafeSiteUrl("OMD_SITE is not set")
    parsed = urlsplit(raw_url)
    if parsed.scheme not in {"http", "https"}:
        raise UnsafeSiteUrl("site URL must use http or https")
    if parsed.username or parsed.password or parsed.query or parsed.fragment:
        raise UnsafeSiteUrl("site URL must not contain credentials, a query, or a fragment")
    if not _is_loopback_host(parsed.hostname):
        raise UnsafeSiteUrl(
            "the local automation secret may only be sent to localhost or a loopback address"
        )
    if parsed.path.rstrip("/") != f"/{site}":
        raise UnsafeSiteUrl(f"site URL must point to the local site /{site}")
    return urlunsplit((parsed.scheme, parsed.netloc, f"/{site}", "", ""))


def automation_credentials() -> tuple[str, str]:
    omd_root = environ.get("OMD_ROOT")
    if not omd_root:
        raise RuntimeError("OMD_ROOT is not set")
    secret_path = Path(omd_root) / "var/check_mk/web/automation/automation.secret"
    return "automation", secret_path.read_text(encoding="utf-8").strip()


class AgentServiceCounter:
    def __init__(self, timeout: float, path: str, config: list[list[str]]):
        self.timeout = timeout
        self.site_url = local_site_base_url(path)
        self.config = config
        username, secret = automation_credentials()
        self.session = requests.Session()
        self.session.trust_env = False
        self.session.headers.update(
            {
                "Authorization": f"Bearer {username} {secret}",
                "Accept": "application/json",
            }
        )

    def get(self, endpoint: str, params: dict[str, object]) -> dict[str, object]:
        response = self.session.get(
            f"{self.site_url}/check_mk/api/1.0{endpoint}",
            params=params,
            timeout=self.timeout,
        )
        response.raise_for_status()
        data = response.json()
        if not isinstance(data, dict):
            raise RuntimeError("Checkmk API returned a non-object JSON response")
        return data

    def get_services(self) -> int:
        print("<<<service_metric_counter:sep(58)>>>")
        for service_name, ls_filter, metric, metric_label in self.config:
            sub_expr = []
            for sub in ls_filter.split(";"):
                sub = sub.strip()
                if "~" in sub:
                    operator = "~"
                elif "=" in sub:
                    operator = "="
                else:
                    raise ValueError(f"invalid filter expression: {sub}")
                left, right = sub.split(operator, 1)
                sub_expr.append({"op": operator, "left": left, "right": right})

            data = self.get(
                "/domain-types/service/collections/all",
                {
                    "query": json.dumps({"op": "or", "expr": [{"op": "and", "expr": sub_expr}]}),
                    "columns": ["performance_data"],
                },
            )
            values = data.get("value", [])
            if not isinstance(values, list):
                raise RuntimeError("Checkmk API response has no valid value list")

            total = 0.0
            for service in values:
                if not isinstance(service, dict):
                    continue
                extensions = service.get("extensions")
                perfdata = extensions.get("performance_data") if isinstance(extensions, dict) else None
                value = perfdata.get(metric) if isinstance(perfdata, dict) else None
                if isinstance(value, (int, float)):
                    total += value
            print(f"{service_name}:{total}:{metric}:{metric_label}")
        return 0


def _safe_summary(error: Exception) -> str:
    return str(error).replace("\n", " ").replace("\r", " ").replace('"', "'")[:500]


def main(argv: list[str] | None = None) -> int:
    args = list(sys.argv[1:] if argv is None else argv)
    if len(args) < 3:
        raise ValueError("expected timeout, local site URL, and at least one service filter")
    timeout = float(args[0])
    if timeout <= 0:
        raise ValueError("timeout must be greater than zero")
    config = [entry.split("|", 3) for entry in args[2:]]
    if any(len(entry) != 4 for entry in config):
        raise ValueError("invalid service filter argument")
    return AgentServiceCounter(timeout, args[1], config).get_services()


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except (OSError, ValueError, RuntimeError, requests.RequestException) as exc:
        print("<<<local>>>")
        print(f'3 "Service Metric Counter" - {_safe_summary(exc)}')
        raise SystemExit(0) from exc
