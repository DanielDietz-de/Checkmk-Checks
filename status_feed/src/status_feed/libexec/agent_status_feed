#!/usr/bin/env python3
"""Fetch public HTTPS RSS/Atom feeds through a bounded parser."""

from __future__ import annotations

import argparse
import html
import ipaddress
import json
import re
import socket
import sys
from datetime import datetime, timezone
from email.utils import parsedate_to_datetime
from typing import Any
from urllib.parse import urlsplit
from xml.etree import ElementTree as ET

import requests

MAX_RESPONSE_BYTES = 2 * 1024 * 1024
MAX_FEEDS = 100
MAX_ITEMS = 1000
MAX_TEXT_LENGTH = 4096

ACTIVE_KEYWORDS = (
    "investigating", "identified", "monitoring", "degraded", "degradation",
    "partial outage", "major outage", "service disruption", "disruption",
    "increased error", "elevated error", "in progress", "ongoing",
)
RESOLVED_KEYWORDS = (
    "resolved", "operational", "completed", "back to normal",
    "fully restored", "all systems",
)


class FeedError(RuntimeError):
    """Raised when a feed target or document is unsafe."""


def validate_public_https_url(value: str) -> str:
    parsed = urlsplit(value.strip())
    if parsed.scheme != "https" or not parsed.hostname:
        raise FeedError("feed URL must be an absolute HTTPS URL")
    if parsed.username or parsed.password or parsed.fragment:
        raise FeedError("feed URL must not contain credentials or a fragment")
    try:
        addresses = {
            result[4][0]
            for result in socket.getaddrinfo(
                parsed.hostname,
                parsed.port or 443,
                type=socket.SOCK_STREAM,
            )
        }
    except socket.gaierror as exc:
        raise FeedError(f"DNS resolution failed: {exc}") from exc
    if not addresses or any(
        not ipaddress.ip_address(address).is_global for address in addresses
    ):
        raise FeedError("feed URL resolves to a non-public address")
    return value.strip()


def parse_date(value: str | None) -> datetime | None:
    if not value or len(value) > 256:
        return None
    value = value.strip()
    try:
        parsed = parsedate_to_datetime(value)
    except (TypeError, ValueError):
        parsed = None
    if parsed is None:
        try:
            parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
        except ValueError:
            return None
    return parsed.replace(tzinfo=timezone.utc) if parsed.tzinfo is None else parsed


def clean_text(value: str | None, limit: int = MAX_TEXT_LENGTH) -> str:
    text = html.unescape(value or "")
    text = re.sub(r"<[^>]{0,2048}>", " ", text)
    text = re.sub(r"[\x00-\x1f\x7f]", " ", text)
    return " ".join(text.split())[:limit]


def classify_state(title: str, summary: str) -> str:
    haystack = f"{title} {summary}".lower()
    positions = {
        keyword: haystack.find(keyword)
        for keyword in (*ACTIVE_KEYWORDS, *RESOLVED_KEYWORDS)
        if keyword in haystack
    }
    if not positions:
        return "unknown"
    first = min(positions, key=positions.get)
    return "resolved" if first in RESOLVED_KEYWORDS else "active"


def extract_items(xml_bytes: bytes) -> list[dict[str, str]]:
    upper = xml_bytes[:4096].upper()
    if b"<!DOCTYPE" in upper or b"<!ENTITY" in upper:
        raise FeedError("DTD and entity declarations are not allowed")
    try:
        root = ET.fromstring(xml_bytes)
    except ET.ParseError as exc:
        raise FeedError(f"feed is not valid XML: {exc}") from exc
    items: list[dict[str, str]] = []
    ns = {"atom": "http://www.w3.org/2005/Atom"}

    for item in root.iter("item"):
        items.append(
            {
                "title": clean_text(item.findtext("title")),
                "published": clean_text(item.findtext("pubDate"), 256),
                "summary": clean_text(item.findtext("description")),
            }
        )
        if len(items) > MAX_ITEMS:
            raise FeedError("feed contains too many items")

    for entry in root.iter("{http://www.w3.org/2005/Atom}entry"):
        title = entry.findtext("atom:title", default="", namespaces=ns)
        published = entry.findtext("atom:updated", default="", namespaces=ns) or entry.findtext(
            "atom:published", default="", namespaces=ns
        )
        summary = entry.findtext("atom:summary", default="", namespaces=ns) or entry.findtext(
            "atom:content", default="", namespaces=ns
        )
        items.append(
            {
                "title": clean_text(title),
                "published": clean_text(published, 256),
                "summary": clean_text(summary),
            }
        )
        if len(items) > MAX_ITEMS:
            raise FeedError("feed contains too many items")

    items.sort(
        key=lambda item: parse_date(item["published"])
        or datetime.min.replace(tzinfo=timezone.utc),
        reverse=True,
    )
    return items


def read_bounded(response: requests.Response) -> bytes:
    body = bytearray()
    for chunk in response.iter_content(chunk_size=65536):
        body.extend(chunk)
        if len(body) > MAX_RESPONSE_BYTES:
            raise FeedError("feed exceeds the 2 MiB limit")
    return bytes(body)


def probe_feed(
    name: str,
    url: str,
    timeout: float,
    user_agent: str,
    session: requests.Session,
) -> dict[str, Any]:
    result: dict[str, Any] = {
        "name": clean_text(name, 256),
        "url": url[:2048],
        "ok": False,
        "error": None,
        "items": 0,
        "latest_title": None,
        "latest_published": None,
        "latest_age_seconds": None,
        "latest_summary": None,
        "latest_state": None,
        "http_status": None,
    }
    try:
        target = validate_public_https_url(url)
        response = session.get(
            target,
            headers={"User-Agent": clean_text(user_agent, 256)},
            timeout=timeout,
            verify=True,
            allow_redirects=False,
            stream=True,
        )
        result["http_status"] = response.status_code
        if response.is_redirect:
            raise FeedError("feed returned an unexpected redirect")
        if not 200 <= response.status_code < 300:
            raise FeedError(f"feed returned HTTP {response.status_code}")
        items = extract_items(read_bounded(response))
        result["ok"] = True
        result["items"] = len(items)
        if items:
            latest = items[0]
            result["latest_title"] = latest["title"] or None
            result["latest_published"] = latest["published"] or None
            result["latest_summary"] = latest["summary"][:500] or None
            result["latest_state"] = classify_state(
                latest["title"], latest["summary"]
            )
            parsed = parse_date(latest["published"])
            if parsed is not None:
                result["latest_age_seconds"] = max(
                    0,
                    int((datetime.now(timezone.utc) - parsed).total_seconds()),
                )
    except (FeedError, requests.RequestException, ValueError) as exc:
        result["error"] = str(exc)[:1024]
    return result


def split_feed(spec: str) -> tuple[str, str]:
    if "=" not in spec:
        raise ValueError("feed spec must be NAME=URL")
    name, url = (part.strip() for part in spec.split("=", 1))
    if not name or not url:
        raise ValueError("feed name and URL are required")
    return name, url


def parse_arguments(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--feed", action="append", default=[])
    parser.add_argument("--timeout", type=float, default=15.0)
    parser.add_argument("--user-agent", default="checkmk-status-feed/2.0")
    args = parser.parse_args(argv)
    if not args.feed:
        parser.error("At least one --feed is required")
    if len(args.feed) > MAX_FEEDS:
        parser.error(f"At most {MAX_FEEDS} feeds are supported")
    if not 0.5 <= args.timeout <= 60:
        parser.error("--timeout must be between 0.5 and 60 seconds")
    return args


def main(argv: list[str] | None = None) -> int:
    args = parse_arguments(argv)
    session = requests.Session()
    session.trust_env = False
    print("<<<status_feed:sep(0)>>>")
    for spec in args.feed:
        try:
            name, url = split_feed(spec)
            result = probe_feed(name, url, args.timeout, args.user_agent, session)
        except ValueError as exc:
            result = {"name": clean_text(spec, 256), "url": "", "ok": False, "error": str(exc)}
        print(json.dumps(result, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
